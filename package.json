{
  "name": "lobster-lark-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-enabled Lark knowledge and assistant service for Lobster.",
  "scripts": {
    "start": "node src/http-only.mjs",
    "start:full": "node src/index.mjs",
    "test": "node --test",
    "test:ci": "npm run check:dependencies && npm run check:test-db-guardrails && node --test",
    "test:workflow:smoke": "node scripts/run-workflow-baseline.mjs smoke",
    "test:workflow:integration": "node scripts/run-workflow-baseline.mjs integration",
    "test:workflow:meeting": "node scripts/run-workflow-baseline.mjs meeting",
    "test:workflow:doc-rewrite": "node scripts/run-workflow-baseline.mjs doc-rewrite",
    "test:workflow:cloud-doc": "node scripts/run-workflow-baseline.mjs cloud-doc",
    "test:workflow:all": "node scripts/run-workflow-baseline.mjs all",
    "test:real-user-usability": "node --test tests/real-user-usability-regression.test.mjs",
    "eval:long-task": "node scripts/evaluate-long-task-governance.mjs",
    "eval:usage-layer": "node evals/usage-layer/usage-layer-runner.mjs",
    "routing:closed-loop": "node scripts/routing-eval-closed-loop.mjs",
    "routing:diagnostics": "node scripts/routing-diagnostics.mjs",
    "control:diagnostics": "node scripts/control-diagnostics.mjs",
    "daily-status": "node scripts/daily-status.mjs",
    "self-check": "node scripts/self-check.mjs",
    "release-check": "node scripts/release-check.mjs",
    "check:daily": "npm run daily-status --",
    "check:self": "npm run self-check --",
    "check:release": "npm run release-check --",
    "check:dependencies": "node scripts/dependency-guardrails.mjs",
    "check:test-db-guardrails": "node scripts/test-db-guardrails.mjs",
    "check:test-db-factory": "node scripts/test-db-guardrails.mjs --check factory",
    "check:routing": "npm run routing:diagnostics --",
    "check:planner": "npm run planner:diagnostics --",
    "check:planner-visible-skill": "node scripts/planner-visible-skill-check.mjs",
    "release-check:ci": "node scripts/release-check-ci.mjs",
    "lint:test-db": "node scripts/test-db-guardrails.mjs --check direct-import",
    "planner:contract-check": "node scripts/planner-contract-check.mjs",
    "planner:diagnostics": "node scripts/planner-diagnostics.mjs",
    "monitor": "node scripts/monitoring-cli.mjs",
    "auth:check": "node scripts/check-auth.mjs",
    "sync:full": "curl -X POST http://localhost:3333/sync/full",
    "sync:incremental": "curl -X POST http://localhost:3333/sync/incremental"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3"
  }
}
